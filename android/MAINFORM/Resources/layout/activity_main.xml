<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F1E8"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#171717"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp">

        <Button
            android:id="@+id/buttonSelectDepartment"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:backgroundTint="#1F7A53"
            android:paddingHorizontal="12dp"
            android:text="@string/select_department"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/buttonRefresh"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#FFFFFF"
            android:text="@string/refresh"
            android:textAllCaps="false"
            android:textColor="#1A1A1A" />

        <Button
            android:id="@+id/buttonExit"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#A33B32"
            android:text="@string/exit_app"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/textCurrentPage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9F0"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="@string/no_department_selected"
        android:textColor="#2E2E2E"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textAuthorCredit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9F0"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"
        android:text="@string/author_credit"
        android:textColor="#6F6658"
        android:textSize="11sp" />

    <LinearLayout
        android:id="@+id/photoControlsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9F0"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/buttonPhoto"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:backgroundTint="#F0B541"
            android:text="@string/choose_image"
            android:textAllCaps="false"
            android:textColor="#1A1A1A" />

        <Button
            android:id="@+id/buttonClearPhoto"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#FFFFFF"
            android:text="@string/clear_image"
            android:textAllCaps="false"
            android:textColor="#1A1A1A" />
    </LinearLayout>

    <TextView
        android:id="@+id/textPhotoStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9F0"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp"
        android:text="@string/photo_not_selected"
        android:textColor="#8A4A00"
        android:textSize="13sp"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/imagePhotoPreview"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:adjustViewBounds="true"
        android:background="#FFF9F0"
        android:contentDescription="@string/photo_preview_title"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:visibility="gone" />

    <WebView
        android:id="@+id/mainWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
